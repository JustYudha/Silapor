PORT=5000
NODE_ENV=development

# === AWS RDS (production / tes ke cloud) ===
DB_HOST=silapor-db.xxxxx.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASS=password_rds_dari_console
DB_NAME=silapor-db

# === Laragon lokal (development) ===
# DB_HOST=localhost
# DB_USER=root
# DB_PASS=

JWT_SECRET=ganti-dengan-string-panjang-random
JWT_EXPIRES_IN=7d

# S3 (region harus sama dengan bucket)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=silapor-storage-yudha
CLOUDFRONT_URL=https://ik.imagekit.io/your_id/

USE_LOCAL_STORAGE=false
API_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# ImageKit (opsional)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
