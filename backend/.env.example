# Server
PORT=5000
NODE_ENV=development

# MySQL (lokal XAMPP: user root, password kosong)
# MySQL RDS (production): isi host RDS
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=silapor_kopo

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Mode lokal: simpan file di folder uploads/ (tanpa AWS)
USE_LOCAL_STORAGE=true
API_BASE_URL=http://localhost:5000

# AWS S3 (production — kosongkan USE_LOCAL_STORAGE)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=silapor-kopo-uploads

# ImageKit CDN
IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id

# CORS
FRONTEND_URL=http://localhost:5173
