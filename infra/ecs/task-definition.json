{
  "family": "silapor-kopo-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/silaporTaskRole",
  "containerDefinitions": [
    {
      "name": "silapor-backend",
      "image": "ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/silapor-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" },
        { "name": "AWS_REGION", "value": "us-east-1" },
        { "name": "DB_NAME", "value": "silapor" },
        { "name": "DB_PORT", "value": "3306" },
        { "name": "S3_BUCKET", "value": "silapor-storage-yudha" },
        { "name": "CLOUDFRONT_URL", "value": "https://ik.imagekit.io/udin21/" }
      ],
      "secrets": [
        { "name": "DB_HOST", "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:silapor/db:host::" },
        { "name": "DB_USER", "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:silapor/db:user::" },
        { "name": "DB_PASS", "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:silapor/db:password::" },
        { "name": "JWT_SECRET", "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:silapor/jwt::" },
        { "name": "AWS_ACCESS_KEY_ID", "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:silapor/aws:access_key_id::" },
        { "name": "AWS_SECRET_ACCESS_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:silapor/aws:secret_access_key::" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/silapor-kopo",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "backend"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:3000/api/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
